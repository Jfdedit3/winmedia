<Window x:Class="WinMedia.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WinMedia"
        Height="840"
        Width="1440"
        MinHeight="700"
        MinWidth="1150"
        Background="#0B1220"
        Foreground="#F8FAFC"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#111827"/>
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#1F2937"/>
        <SolidColorBrush x:Key="BorderBrushCustom" Color="#243041"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="AccentBrushHover" Color="#1D4ED8"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#94A3B8"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBrushHover}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#182234"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushCustom}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushCustom}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" CornerRadius="20" Padding="18" BorderBrush="{StaticResource BorderBrushCustom}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock Text="WinMedia" FontSize="28" FontWeight="Bold"/>
                    <TextBlock Text="Galerie multimédia Windows moderne avec aperçu image et vidéo." FontSize="14" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="OpenFolderButton" Content="Open folder" Style="{StaticResource PrimaryButtonStyle}" Click="OpenFolderButton_Click"/>
                    <Button x:Name="RefreshButton" Content="Refresh" Style="{StaticResource SecondaryButtonStyle}" Click="RefreshButton_Click"/>
                </StackPanel>

                <Grid Grid.Row="2" Grid.ColumnSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.1*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="0.9*"/>
                        <ColumnDefinition Width="0.9*"/>
                        <ColumnDefinition Width="0.75*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,14,0">
                        <TextBlock Text="Current folder" FontWeight="SemiBold"/>
                        <TextBlock x:Name="CurrentFolderText" Text="No folder selected" Margin="0,8,0,0" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,14,0">
                        <TextBlock Text="Search" FontWeight="SemiBold"/>
                        <TextBox x:Name="SearchTextBox" Margin="0,8,0,0" TextChanged="SearchTextBox_TextChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,14,0">
                        <TextBlock Text="Filter" FontWeight="SemiBold"/>
                        <ComboBox x:Name="FilterComboBox" Margin="0,8,0,0" SelectionChanged="FilterComboBox_SelectionChanged">
                            <ComboBoxItem Content="All" IsSelected="True"/>
                            <ComboBoxItem Content="Images"/>
                            <ComboBoxItem Content="Videos"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="0,0,14,0">
                        <TextBlock Text="Sort by" FontWeight="SemiBold"/>
                        <ComboBox x:Name="SortComboBox" Margin="0,8,0,0" SelectionChanged="SortComboBox_SelectionChanged">
                            <ComboBoxItem Content="Name" IsSelected="True"/>
                            <ComboBoxItem Content="Date modified"/>
                            <ComboBoxItem Content="Size"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Order" FontWeight="SemiBold"/>
                        <CheckBox x:Name="DescendingCheckBox" Margin="4,13,0,0" Content="Descending" Foreground="White" Checked="DescendingCheckBox_Changed" Unchecked="DescendingCheckBox_Changed"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" CornerRadius="20" Padding="14" BorderBrush="{StaticResource BorderBrushCustom}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0">
                        <TextBlock Text="Gallery" FontSize="20" FontWeight="Bold" DockPanel.Dock="Left"/>
                        <TextBlock x:Name="ResultsText" Text="0 items" FontSize="14" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Right"/>
                    </DockPanel>

                    <ListBox x:Name="GalleryListBox" Grid.Row="2" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionChanged="GalleryListBox_SelectionChanged">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel IsItemsHost="True" Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Width="220" Margin="0,0,14,14" Padding="10" Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrushCustom}" BorderThickness="1" CornerRadius="18">
                                    <StackPanel>
                                        <Grid Height="150">
                                            <Border CornerRadius="14" Background="#0F172A"/>
                                            <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" ClipToBounds="True">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsVideo}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                            <Border CornerRadius="14" Background="#0F172A">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsVideo}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock Text="▶" FontSize="38" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Extension}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" Margin="0,10,0,0" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding MediaType}" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                                        <TextBlock Text="{Binding ModifiedLabel}" Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0"/>
                                        <TextBlock Text="{Binding DisplaySize}" Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}" CornerRadius="20" Padding="18" BorderBrush="{StaticResource BorderBrushCustom}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="280"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Preview" FontSize="20" FontWeight="Bold"/>

                    <Border Grid.Row="2" Background="#0F172A" CornerRadius="18" BorderBrush="{StaticResource BorderBrushCustom}" BorderThickness="1" Padding="10">
                        <Grid>
                            <Image x:Name="PreviewImage" Stretch="Uniform" Visibility="Collapsed"/>
                            <MediaElement x:Name="PreviewVideo" LoadedBehavior="Manual" UnloadedBehavior="Stop" Stretch="Uniform" Visibility="Collapsed" MediaOpened="PreviewVideo_MediaOpened" MediaFailed="PreviewVideo_MediaFailed"/>
                            <TextBlock x:Name="PreviewPlaceholderText" Text="Select an image or video to preview it here." Foreground="{StaticResource MutedBrush}" FontSize="16" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap" Width="280"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
                        <Button x:Name="PlayButton" Content="Play" Style="{StaticResource SecondaryButtonStyle}" Click="PlayButton_Click" IsEnabled="False"/>
                        <Button x:Name="PauseButton" Content="Pause" Style="{StaticResource SecondaryButtonStyle}" Click="PauseButton_Click" IsEnabled="False"/>
                        <Button x:Name="StopButton" Content="Stop" Style="{StaticResource SecondaryButtonStyle}" Click="StopButton_Click" IsEnabled="False"/>
                        <Button x:Name="OpenInExplorerButton" Content="Show in Explorer" Style="{StaticResource SecondaryButtonStyle}" Click="OpenInExplorerButton_Click" IsEnabled="False" Margin="8,0,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="5">
                        <TextBlock x:Name="SelectedNameText" Text="No media selected" FontSize="18" FontWeight="Bold" TextWrapping="Wrap"/>
                        <TextBlock x:Name="SelectedTypeText" Text="" Margin="0,10,0,0" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                        <TextBlock x:Name="SelectedPathText" Text="" Margin="0,8,0,0" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                        <TextBlock x:Name="SelectedMetaText" Text="" Margin="0,8,0,0" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                    </StackPanel>

                    <TextBlock Grid.Row="6" x:Name="StatusText" Text="Ready" Foreground="{StaticResource MutedBrush}" Margin="0,16,0,0"/>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="#0A1020" BorderBrush="{StaticResource BorderBrushCustom}" BorderThickness="1" CornerRadius="16" Padding="12,10" Margin="0,18,0,0">
            <DockPanel>
                <TextBlock Text="Supported images: jpg, jpeg, png, bmp, gif" Foreground="{StaticResource MutedBrush}"/>
                <TextBlock Text="Supported videos: mp4, mov, wmv, avi, m4v" Foreground="{StaticResource MutedBrush}" DockPanel.Dock="Right"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
